# =============================================
# Interpol Watcher - Environment Configuration
# =============================================

# Interpol API
INTERPOL_API_URL=https://ws-public.interpol.int/notices/v1/red
INTERPOL_PAGE=1
INTERPOL_RESULT_PER_PAGE=20

# Fetch interval (saniye cinsinden)
FETCH_INTERVAL=60

# RabbitMQ
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=admin
RABBITMQ_PASS=admin123
QUEUE_NAME=interpol_red_notices

# Web Server
FLASK_HOST=0.0.0.0
FLASK_PORT=5000
FLASK_DEBUG=false

# Database
DB_PATH=/app/data/interpol.db
