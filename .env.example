# ── Interpol Fetcher ────────────────────────────────────────────────────────
INTERPOL_BASE_URL=https://ws-public.interpol.int
INTERPOL_FETCH_INTERVAL_SECONDS=300

INTERPOL_FETCH_ALL=true
INTERPOL_FETCH_EXTENDED=false

# ── Yeni Pass Kontrolleri ────────────────────────────────────────────────────
# Pass A: age 0-9 taraması (daha önce hiç çekilmedi)
ENABLE_PASS_AGE_0_9=true

# Pass B: IN, PK (ve eklenenler) için 1-yıllık yaş aralıkları
ENABLE_PASS_IN_PK_1YR=true
VERY_HIGH_NATIONALITIES_1YR=IN,PK

# Pass B yaş aralığı sınırları
AGE_1YR_MIN=10
AGE_1YR_MAX=99

# ── Rate Limiting ────────────────────────────────────────────────────────────
# İstekler arası bekleme süresi (saniye). Min 1.5 önerilir (max ~2000 req/saat).
# 1000 req/saat sınırı için: REQUEST_DELAY_SECONDS=3.6
REQUEST_DELAY_SECONDS=2.0

# ── Sürdürülebilirlik (Resumable State) ─────────────────────────────────────
# Hangi passler tamamlandı bilgisi burada saklanır. Fetcher kapanıp açılırsa
# kaldığı yerden devam eder. /data docker volume'ında kalıcıdır.
STATE_FILE_PATH=/data/scan_state.json

# ── RabbitMQ ────────────────────────────────────────────────────────────────
RABBITMQ_DEFAULT_USER=guest
RABBITMQ_DEFAULT_PASS=guest
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_QUEUE_NAME=interpol_red_notices
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest

# ── Web Uygulaması ──────────────────────────────────────────────────────────
FLASK_ENV=production
DATABASE_URL=sqlite:////data/notices.db
